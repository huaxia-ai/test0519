{
  "name": "pomodoro-timer",
  "version": "1.0.0",
  "description": "桌面番茄钟计时器",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.pomodoro.timer",
    "productName": "番茄钟",
    "win": {
      "target": "portable"
    },
    "portable": {
      "artifactName": "番茄钟.exe"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
